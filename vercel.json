{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend-app/assets/$1"
    },
    {
      "src": "/(favicon.ico|manifest.json|robots.txt|logo.*|letterhead.*)",
      "dest": "/frontend-app/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend-app/index.html"
    }
  ]
}
