# Runtime
ENVIRONMENT=development
LOG_LEVEL=info
ENABLE_API_DOCS=true
FORCE_HTTPS=false

# CORS
# Comma-separated allowed origins. Do not use "*" in production.
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Authentication / sessions
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
TOKEN_TTL_HOURS=12

# Login protection
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SEC=300
LOGIN_RATE_LIMIT_LOCKOUT_SEC=900

# Optional JWT settings (if you add JWT-based auth later)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Storage / DB
STORAGE_DIR=./data
DB_PATH=./data/app.db
DATABASE_URL=sqlite:///./data/app.db

# Upload constraints
MAX_UPLOAD_FILES=5
MAX_FILE_MB=10

# Office access controls
OFFICE_IPS=203.0.113.0/24,198.51.100.10
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_M=100
GEO_GRANT_MINUTES=10

# Optional integrations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
