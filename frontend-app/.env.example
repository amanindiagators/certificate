# Frontend env vars are bundled into browser JS.
# Never store secrets here.

# Leave these blank on single-project Vercel deployment.
# The app will call same-origin /api automatically in production.
VITE_BACKEND_URL=
REACT_APP_BACKEND_URL=
NEXT_PUBLIC_BACKEND_URL=
ENABLE_HEALTH_CHECK=false

# Local dev only
WDS_SOCKET_PORT=3000
